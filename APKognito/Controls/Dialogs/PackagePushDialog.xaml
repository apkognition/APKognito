<ui:ContentDialog
    x:Class="APKognito.Controls.Dialogs.PackagePushDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:APKognito.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:APKognito.Controls.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Push a package"
    HorizontalAlignment="Stretch"
    d:DataContext="{d:DesignInstance local:PackagePushDialog,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    CloseButtonText="Cancel"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    PrimaryButtonText="Continue"
    mc:Ignorable="d">

    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}" TargetType="{x:Type local:PackagePushDialog}" />
    </ui:ContentDialog.Resources>

    <Grid Width="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <ui:TextBlock Margin="0,0,0,5" Text="Select package" />
            <c:DirectorySelector DirectoryPath="{Binding ViewModel.PackagePath, UpdateSourceTrigger=PropertyChanged}" SelectingDirectory="False" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="10">
            <ui:TextBlock Margin="0,0,0,5" Text="Select asset directory (leave empty if there are no assets)" />
            <c:DirectorySelector DirectoryPath="{Binding ViewModel.AssetsPath, UpdateSourceTrigger=PropertyChanged}" SelectingDirectory="False" />
        </StackPanel>
    </Grid>
</ui:ContentDialog>
